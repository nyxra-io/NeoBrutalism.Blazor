@page "/components/footer"

<NBTitle Variant="@NBTitleVariant.Title">Footer</NBTitle>
<NBTitle Variant="@NBTitleVariant.Subtitle">A structured multi-column footer with slots for link columns, social icons, and copyright text. Responsive: columns stack on mobile.</NBTitle>

<NBTitle Variant="@NBTitleVariant.Section">Default</NBTitle>
<DemoBlock Code="@CS.FooterDefault">
    <Preview>
        <NBFooter Copyright="© 2026 Acme Inc. All rights reserved.">
            <Columns>
                <NBFooterColumn Title="Product">
                    <a href="#">Features</a>
                    <a href="#">Pricing</a>
                    <a href="#">Changelog</a>
                </NBFooterColumn>
                <NBFooterColumn Title="Company">
                    <a href="#">About</a>
                    <a href="#">Blog</a>
                    <a href="#">Careers</a>
                </NBFooterColumn>
                <NBFooterColumn Title="Legal">
                    <a href="#">Privacy</a>
                    <a href="#">Terms</a>
                </NBFooterColumn>
            </Columns>
        </NBFooter>
    </Preview>
</DemoBlock>

