@inherits LayoutComponentBase
@inject NavigationManager Navigation
@implements IDisposable

<header class="docs-header">
    <button class="docs-header__toggle" @onclick="ToggleSidebar" aria-label="Toggle navigation">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
    </button>
    <a href="" class="docs-header__logo">
        <img src="images/logo.png" alt="NeoBrutalism Blazor logo" class="docs-header__logo-img" />
        NeoBrutalism <span>Blazor</span>
    </a>
    <div class="docs-header__links">
        <a href="https://www.nuget.org/packages/NeoBrutalism.Blazor" target="_blank">
            <NBButton Variant="NBButtonVariant.Neutral" Size="NBButtonSize.Small">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>
                NuGet
            </NBButton>
        </a>
        <a href="https://github.com/nyxra-io/NeoBrutalism.Blazor" target="_blank">
            <NBButton Variant="NBButtonVariant.Neutral" Size="NBButtonSize.Small">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                GitHub
            </NBButton>
        </a>
        <a href="api-docs/index.html" target="_blank">
            <NBButton Variant="NBButtonVariant.Neutral" Size="NBButtonSize.Small">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                API Reference
            </NBButton>
        </a>
    </div>
</header>

@if (_sidebarOpen)
{
    <div class="docs-overlay" @onclick="CloseSidebar"></div>
}

<div class="docs-shell">
    <NavMenu AdditionalClass="@(_sidebarOpen ? "docs-sidebar--open" : "")" />
    <main class="docs-main">
        @Body
    </main>
</div>

<NBSonner />

@code {
    private bool _sidebarOpen;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void ToggleSidebar()
    {
        _sidebarOpen = !_sidebarOpen;
    }

    private void CloseSidebar()
    {
        _sidebarOpen = false;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _sidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}


