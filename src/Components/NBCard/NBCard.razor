@namespace NeoBrutalism.Blazor
@* Neo Brutalism Card Component — root container *@

<div class="nb-card @(OnClick.HasDelegate ? "nb-card--clickable" : "")" @onclick="OnClick">
    @ChildContent
</div>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }
}
