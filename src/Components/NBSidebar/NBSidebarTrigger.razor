@namespace NeoBrutalism.Blazor
@* Sidebar Trigger — toggles the sidebar via CascadingParameter *@

<button type="button" class="nb-sidebar-trigger nb-btn nb-btn--noshadow nb-btn--icon"
        aria-label="Toggle Sidebar"
        @onclick="ToggleSidebar">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect width="18" height="18" x="3" y="3" rx="2" /><path d="M9 3v18" />
    </svg>
</button>

@code {
    [CascadingParameter]
    public NBSidebarProvider? Provider { get; set; }

    private async Task ToggleSidebar()
    {
        if (Provider is not null)
            await Provider.ToggleSidebar();
    }
}
