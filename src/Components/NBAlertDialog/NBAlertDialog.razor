@namespace NeoBrutalism.Blazor
@* Neo Brutalism Alert Dialog — confirmation modal without close button *@

@if (_shouldRender)
{
    <div class="nb-dialog-backdrop @(_isClosing ? "nb-dialog-backdrop--closing" : "nb-dialog-backdrop--open")">
        <div class="nb-alert-dialog @(_isClosing ? "nb-dialog--closing" : "nb-dialog--open")" role="alertdialog" aria-modal="true" aria-labelledby="@_titleId" aria-describedby="@_descId" @onclick:stopPropagation="true">
            <div class="nb-dialog__header">
                @if (!string.IsNullOrWhiteSpace(Title))
                {
                    <div class="nb-dialog__title" id="@_titleId">@Title</div>
                }
                @if (!string.IsNullOrWhiteSpace(Description))
                {
                    <div class="nb-dialog__description" id="@_descId">@Description</div>
                }
            </div>
            @if (ChildContent is not null)
            {
                <div class="nb-dialog__body">
                    @ChildContent
                </div>
            }
            <div class="nb-alert-dialog__footer">
                <NBButton Variant="@NBButtonVariant.Neutral" OnClick="HandleCancel">@CancelText</NBButton>
                <NBButton Variant="@ConfirmVariant" OnClick="HandleConfirm">@ConfirmText</NBButton>
            </div>
        </div>
    </div>
}

@code {
    private const int AnimationDurationMs = 200;
    private readonly string _titleId = $"nb-alert-dialog-title-{Guid.NewGuid():N}";
    private readonly string _descId = $"nb-alert-dialog-desc-{Guid.NewGuid():N}";
    private bool _shouldRender;
    private bool _isClosing;
    private bool _previousIsVisible;

    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter, EditorRequired]
    public string Title { get; set; } = string.Empty;

    [Parameter]
    public string? Description { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public EventCallback OnConfirm { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public string ConfirmText { get; set; } = "Continue";

    [Parameter]
    public string CancelText { get; set; } = "Cancel";

    [Parameter]
    public NBButtonVariant ConfirmVariant { get; set; } = NBButtonVariant.Danger;

    protected override void OnParametersSet()
    {
        if (IsVisible && !_previousIsVisible)
        {
            _shouldRender = true;
            _isClosing = false;
        }
        else if (!IsVisible && _previousIsVisible)
        {
            _isClosing = true;
            _ = RemoveAfterAnimationAsync();
        }
        _previousIsVisible = IsVisible;
    }

    [ExcludeFromCodeCoverage]
    private async Task RemoveAfterAnimationAsync()
    {
        await Task.Delay(AnimationDurationMs);
        if (_isClosing)
        {
            _shouldRender = false;
            _isClosing = false;
            StateHasChanged();
        }
    }

    private async Task HandleConfirm() => await OnConfirm.InvokeAsync();

    private async Task HandleCancel() => await OnCancel.InvokeAsync();
}
