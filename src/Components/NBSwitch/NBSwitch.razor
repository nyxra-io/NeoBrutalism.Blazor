@namespace NeoBrutalism.Blazor
@* Neo Brutalism Switch — toggle input *@

<label class="nb-switch @(Disabled ? "nb-switch--disabled" : "")">
    <input type="checkbox"
           class="nb-switch__input"
           checked="@Checked"
           disabled="@Disabled"
           @onchange="OnChange" />
    <span class="nb-switch__track">
        <span class="nb-switch__thumb"></span>
    </span>
    @if (!string.IsNullOrEmpty(Label))
    {
        <span class="nb-switch__label">@Label</span>
    }
</label>

@code {
    [Parameter]
    public bool Checked { get; set; }

    [Parameter]
    public EventCallback<bool> CheckedChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Label { get; set; }

    private async Task OnChange(ChangeEventArgs e)
        => await CheckedChanged.InvokeAsync(e.Value is true);
}
