@namespace NeoBrutalism.Blazor
@* Neo Brutalism Avatar *@

<span class="nb-avatar @(Size != NBAvatarSize.Default ? $"nb-avatar--{Size.ToString().ToLowerInvariant()}" : "")">
    @if (!string.IsNullOrEmpty(Src))
    {
        <img src="@Src" alt="@Alt" class="nb-avatar__img" />
    }
    else if (!string.IsNullOrEmpty(Initials))
    {
        <span class="nb-avatar__initials">@Initials</span>
    }
    else
    {
        <span class="nb-avatar__fallback">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
            </svg>
        </span>
    }
</span>

@code {
    [Parameter]
    public string? Src { get; set; }

    [Parameter]
    public string? Alt { get; set; }

    /// <summary>Up to 2 characters shown as fallback when no image is provided.</summary>
    [Parameter]
    public string? Initials { get; set; }

    [Parameter]
    public NBAvatarSize Size { get; set; } = NBAvatarSize.Default;
}
