@namespace NeoBrutalism.Blazor
@* Neo Brutalism Radio Group *@

<div class="nb-radio-group" role="radiogroup">
    @foreach (var option in Options)
    {
        <label class="nb-radio-item @(Disabled || option.Disabled ? "nb-radio-item--disabled" : "")">
            <span class="nb-radio-button @(Value == option.Value ? "nb-radio-button--checked" : "")">
                <input type="radio"
                       name="@_name"
                       value="@option.Value"
                       checked="@(Value == option.Value)"
                       disabled="@(Disabled || option.Disabled)"
                       class="nb-radio-input"
                       @onchange="() => OnChange(option.Value)" />
                @if (Value == option.Value)
                {
                    <span class="nb-radio-dot"></span>
                }
            </span>
            <span>@option.Label</span>
        </label>
    }
</div>

@code {
    private readonly string _name = $"nb-radio-{Guid.NewGuid():N}";

    [Parameter, EditorRequired]
    public IEnumerable<NBRadioOption> Options { get; set; } = [];

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    private async Task OnChange(string value)
        => await ValueChanged.InvokeAsync(value);
}
