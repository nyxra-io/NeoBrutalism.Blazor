@namespace NeoBrutalism.Blazor
@* Neo Brutalism Select Component — custom dropdown *@

<div class="nb-field">
<NBLabel For="@Id">@Label</NBLabel>
<div class="nb-select @(_open ? "nb-select--open" : "") @(Disabled ? "nb-select--disabled" : "")" @onfocusout="HandleFocusOut">
    <button type="button"
            id="@Id"
            class="nb-select__trigger"
            role="combobox"
            aria-expanded="@_open"
            aria-haspopup="listbox"
            aria-controls="@_listId"
            disabled="@Disabled"
            @onclick="ToggleOpen"
            @onkeydown="HandleTriggerKeyDown">
        <span class="nb-select__value @(SelectedLabel is null ? "nb-select__value--placeholder" : "")">
            @(SelectedLabel ?? Placeholder ?? "Select…")
        </span>
        <svg class="nb-select__icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round">
            <path d="m6 9 6 6 6-6"/>
        </svg>
    </button>

    @if (_open)
    {
        <div class="nb-select__content" id="@_listId" role="listbox" aria-labelledby="@Id">
            @foreach (var option in Options)
            {
                var isSelected = option.Value == Value;
                <div class="nb-select__item @(isSelected ? "nb-select__item--selected" : "") @(_focusedValue == option.Value ? "nb-select__item--focused" : "")"
                     role="option"
                     aria-selected="@isSelected"
                     tabindex="-1"
                     @onclick="() => SelectOption(option.Value)"
                     @onclick:stopPropagation="true"
                     @onmouseenter="() => _focusedValue = option.Value">
                    <span class="nb-select__item-check">
                        @if (isSelected)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                 viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <path d="M20 6 9 17l-5-5"/>
                            </svg>
                        }
                    </span>
                    <span>@option.Label</span>
                </div>
            }
        </div>
    }
</div>
@if (!string.IsNullOrWhiteSpace(Subtitle))
{
    <p class="nb-field-subtitle">@Subtitle</p>
}
</div>

@code {
    private readonly string _listId = $"nb-select-list-{Guid.NewGuid():N}";
    private bool _open;
    private string? _focusedValue;

    [Parameter, EditorRequired]
    public string Label { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public string Id { get; set; } = string.Empty;

    [Parameter, EditorRequired]
    public IEnumerable<NBSelectOption> Options { get; set; } = [];

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string? Subtitle { get; set; }

    private string? SelectedLabel => Options.FirstOrDefault(o => o.Value == Value)?.Label;

    private void ToggleOpen()
    {
        if (Disabled) return;
        _open = !_open;
        if (_open) _focusedValue = Value;
    }

    private async Task SelectOption(string value)
    {
        _open = false;
        await ValueChanged.InvokeAsync(value);
    }

    [ExcludeFromCodeCoverage]
    private void HandleFocusOut()
    {
        // Small delay to allow click events on items to fire first
        _ = Task.Delay(150).ContinueWith(_ => InvokeAsync(() => { _open = false; StateHasChanged(); }));
    }

    private void HandleTriggerKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter":
            case " ":
                ToggleOpen();
                break;
            case "Escape":
                _open = false;
                break;
            case "ArrowDown":
                if (!_open) { _open = true; _focusedValue = Value; }
                else MoveFocus(1);
                break;
            case "ArrowUp":
                if (!_open) { _open = true; _focusedValue = Value; }
                else MoveFocus(-1);
                break;
        }
    }

    private void MoveFocus(int direction)
    {
        var list = Options.ToList();
        if (list.Count == 0) return;
        var idx = list.FindIndex(o => o.Value == _focusedValue);
        idx = Math.Clamp(idx + direction, 0, list.Count - 1);
        _focusedValue = list[idx].Value;
    }
}
