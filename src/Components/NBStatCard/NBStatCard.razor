@namespace NeoBrutalism.Blazor
@* Neo Brutalism Stat Card Component *@

<div class="nb-stat-card" @attributes="AdditionalAttributes">
    <div class="nb-stat-card__value">@Value</div>
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <div class="nb-stat-card__label">@Label</div>
    }
    @if (Trend != NBStatCardTrend.None)
    {
        <div class="nb-stat-card__trend nb-stat-card__trend--@Trend.ToString().ToLowerInvariant()">
            @(Trend == NBStatCardTrend.Up ? "↑" : "↓")
        </div>
    }
</div>

@code {
    /// <summary>The large number or value to display prominently.</summary>
    [Parameter, EditorRequired]
    public string Value { get; set; } = string.Empty;

    /// <summary>Descriptive label displayed below the value.</summary>
    [Parameter]
    public string? Label { get; set; }

    /// <summary>Trend direction indicator: <see cref="NBStatCardTrend.None"/>, <see cref="NBStatCardTrend.Up"/>, or <see cref="NBStatCardTrend.Down"/>.</summary>
    [Parameter]
    public NBStatCardTrend Trend { get; set; } = NBStatCardTrend.None;

    /// <summary>Additional HTML attributes applied to the root element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
